#!/bin/bash

source "$HOME/.ai.env"

set -euo pipefail

DRY_RUN=false

usage() {
  echo "Usage:"
  echo "  ai-cli claude \"free prompt\""
  echo "  ai-cli claude debug \"your request\""
  echo "  ai-cli claude feature \"your request\""
  echo "  ai-cli claude refactor \"your request\""
  echo "  ai-cli claude review \"your request\""
  echo "  ai-cli claude planning \"your request\""
  echo ""
  echo "  ai-cli copilot \"free prompt\""
  echo "  ai-cli copilot debug \"your request\""
  echo "  ai-cli copilot feature \"your request\""
  echo "  ai-cli copilot refactor \"your request\""
  echo "  ai-cli copilot review \"your request\""
  echo "  ai-cli copilot planning \"your request\""
  echo ""
  echo "Options:"
  echo "  --dry-run, -d Show the generated prompt without executing"
}

if [ "$#" -eq 0 ]; then
  usage
  exit 1
fi

# Parse --dry-run flag
if [[ "${1:-}" == "--dry-run" || "${1:-}" == "-d" ]]; then
  DRY_RUN=true
  shift
fi

PROVIDER="${1:-}"
COMMAND="${2:-}"
shift || true

if [ "$#" -gt 0 ]; then
  shift || true
fi

PROMPT="$*"

KNOWN_COMMANDS=("debug" "feature" "refactor" "review" "planning")

if [ -z "$COMMAND" ]; then
  usage
  exit 1
fi

if [[ ! " ${KNOWN_COMMANDS[*]} " =~ " ${COMMAND} " ]]; then
  PROMPT="$COMMAND $PROMPT"
  COMMAND="chat"
fi

if [ -z "${PROMPT// }" ]; then
  PROMPT="General $COMMAND request"
fi

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || true)

if [ -z "$REPO_ROOT" ]; then
  echo "Error: Not inside a git repository"
  exit 1
fi

cd "$REPO_ROOT"

# Ensure .ai-private directory exists with proper permissions
AI_PRIVATE_DIR="$REPO_ROOT/.ai-private"
if [ ! -d "$AI_PRIVATE_DIR" ]; then
  mkdir -p "$AI_PRIVATE_DIR"
  chmod 755 "$AI_PRIVATE_DIR"
fi

BASE="$REPO_ROOT/CLAUDE.md"
FEATURE="$AI_PRIVATE_DIR/FEATURE.md"
DEBUG="$AI_PRIVATE_DIR/DEBUG.md"
REFACTOR="$AI_PRIVATE_DIR/REFACTOR.md"
REVIEW="$AI_PRIVATE_DIR/REVIEW.md"
PLANNING="$AI_PRIVATE_DIR/PLANNING.md"

require_files() {
  for file in "$@"; do
    if [ ! -f "$file" ]; then
      echo "Warning: Missing file $file (skipped)"
    fi
  done
}

existing_files() {
  for file in "$@"; do
    [ -f "$file" ] && echo "$file"
  done
}

# Reusable instruction for HTML task visualization
html_task_instruction() {
  echo "Based on the above, create a clean, interactive, professional HTML/CSS/JS self-contained 'plan.html' with modern styling (layout, colors, filters, charts). Save to $AI_PRIVATE_DIR/tasks/plan.html (create folder if needed)."
}

# Note about paths (used in prompts) - uses absolute path
PATH_NOTE="IMPORTANT: All output files must be written to $AI_PRIVATE_DIR/ (absolute path)."

run_ai() {
  local input="$1"
  local model="${2:-}"
  local files_display="${3:-}"
  local prompt_no_static="${4:-$input}"
  local dynamic_cmds="${5:-}"

  echo "═══════════════════════════════════════════════════════════════"
  echo "Provider : $PROVIDER"
  echo "Command  : $COMMAND"
  echo "Branch   : $(git branch --show-current)"
  if [ -n "$model" ]; then
    echo "Model    : $model"
  fi
  echo "Dry-run  : $DRY_RUN"
  echo "═══════════════════════════════════════════════════════════════"

  if [ "$DRY_RUN" = true ]; then
    echo ""
    echo "╔═══════════════════════════════════════════════════════════════╗"
    echo "║                    PROVIDER COMMAND                           ║"
    echo "╚═══════════════════════════════════════════════════════════════╝"
    local cmd_prefix=""
    if [ -n "$files_display" ]; then
      cmd_prefix="cat $files_display"
    fi
    if [ -n "$dynamic_cmds" ]; then
      if [ -n "$cmd_prefix" ]; then
        cmd_prefix="{ $cmd_prefix; $dynamic_cmds; }"
      else
        cmd_prefix="{ $dynamic_cmds; }"
      fi
    fi
    
    case "$PROVIDER" in
      copilot)
        if [ -n "$cmd_prefix" ]; then
          echo "$cmd_prefix | copilot --allow-all-tools --allow-all-paths --add-dir \$REPO_ROOT -p \"<PROMPT>\""
        else
          echo "copilot --allow-all-tools --allow-all-paths --add-dir \$REPO_ROOT -p \"<PROMPT>\""
        fi
        ;;
      claude)
        if [ -n "$cmd_prefix" ]; then
          if [ -n "$model" ]; then
            echo "$cmd_prefix | claude --dangerously-skip-permissions --model $model \"<PROMPT>\""
          else
            echo "$cmd_prefix | claude --dangerously-skip-permissions \"<PROMPT>\""
          fi
        else
          if [ -n "$model" ]; then
            echo "claude --dangerously-skip-permissions --model $model \"<PROMPT>\""
          else
            echo "claude --dangerously-skip-permissions \"<PROMPT>\""
          fi
        fi
        ;;
    esac
    echo ""
    echo "╔═══════════════════════════════════════════════════════════════╗"
    echo "║                    <PROMPT> (without static context)          ║"
    echo "╚═══════════════════════════════════════════════════════════════╝"
    echo "$prompt_no_static"
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "Prompt length: $(echo "$input" | wc -c | tr -d ' ') chars, $(echo "$input" | wc -l | tr -d ' ') lines"
    echo "═══════════════════════════════════════════════════════════════"
    return 0
  fi

  case "$PROVIDER" in
    copilot)
      copilot --allow-all-tools --allow-all-paths --add-dir "$REPO_ROOT" -p "$input"
      ;;
    claude)
      if [ -n "$model" ]; then
        claude --dangerously-skip-permissions --model "$model" "$input"
      else
        claude --dangerously-skip-permissions "$input"
      fi
      ;;
    *)
      echo "Error: Unknown provider '$PROVIDER'"
      usage
      exit 1
      ;;
  esac
}

base_repo_context() {
  cat <<EOF

### BRANCH
$(git branch --show-current)

### REPO STATUS
$(git status --short)

### RECENT COMMITS
$(git log --oneline -8)

EOF
}

changed_files_context() {
  cat <<EOF

### CHANGED FILES AGAINST MASTER
$(git diff --name-only master...HEAD 2>/dev/null || true)

EOF
}

review_context() {
  cat <<EOF

$(base_repo_context)

$(changed_files_context)

EOF
}

feature_context() {
  cat <<EOF

$(base_repo_context)

$(changed_files_context)

### RELEVANT TREE
$(find . -maxdepth 3 \
  -not -path "./.git/*" \
  -not -path "./node_modules/*" \
  -not -path "./dist/*" \
  -not -path "./build/*" \
  -type f | sed 's#^\./##' | head -200)

EOF
}

refactor_context() {
  cat <<EOF

$(base_repo_context)

### STAGED FILES
$(git diff --cached --name-only 2>/dev/null || true)

### UNSTAGED FILES
$(git diff --name-only 2>/dev/null || true)

### CHANGED FILES AGAINST MASTER
$(git diff --name-only master...HEAD 2>/dev/null || true)

EOF
}

debug_context() {
  cat <<EOF

$(base_repo_context)

$(changed_files_context)

### PACKAGE SCRIPTS
$(node -e "try { const p=require('./package.json'); console.log(JSON.stringify(p.scripts,null,2)) } catch(e) {}" 2>/dev/null || true)

EOF
}

planning_context() {
  cat <<EOF

$(base_repo_context)

$(changed_files_context)

### RELEVANT TREE
$(find . -maxdepth 4 \
  -not -path "./.git/*" \
  -not -path "./node_modules/*" \
  -not -path "./dist/*" \
  -not -path "./build/*" \
  -type f | sed 's#^\./##' | head -300)

EOF
}

run() {
  local instruction="$1"
  local dynamic_context="$2"
  local model="${3:-}"
  local dynamic_cmds="${4:-}"
  shift 4 || true

  local files
  files=$(existing_files "$@")

  if [ -z "$files" ]; then
    echo "Error: No valid context files found"
    exit 1
  fi

  # Get relative file paths for display
  local files_display
  files_display=$(echo "$files" | sed "s|$REPO_ROOT/||g" | tr '\n' ' ')

  local static_context
  static_context="$(cat $files 2>/dev/null || true)"

  local full_prompt="
  ### TASK
  $instruction

  ### STATIC CONTEXT
  $static_context

  ### DYNAMIC CONTEXT
  $dynamic_context

  ### USER REQUEST
  $PROMPT
  "

  # Prompt without static context (for dry-run display)
  local prompt_no_static="
  ### TASK
  $instruction

  ### DYNAMIC CONTEXT
  $dynamic_context

  ### USER REQUEST
  $PROMPT
  "

  run_ai "$full_prompt" "$model" "$files_display" "$prompt_no_static" "$dynamic_cmds"
}

case "$COMMAND" in
  chat)
    run_ai "$PROMPT"
    ;;

  debug)
    require_files "$BASE" "$DEBUG"
    run "1) Root cause analysis, 2) Minimal reproduction steps, 3) Smallest safe fix with code changes, 4) Regression tests to prevent recurrence, 5) Write findings to $AI_PRIVATE_DIR/REVIEW.md (if exists, overwrite) with actionable suggestions grouped by severity. $(html_task_instruction) $PATH_NOTE" \
      "$(debug_context)" \
      "" \
      "git status; git log --oneline -5; git log master..HEAD --oneline; git diff --stat master...HEAD" \
      "$BASE" "$DEBUG"
    ;;

  feature)
    require_files "$BASE" "$PLANNING"
    run "Implement the feature specified in $AI_PRIVATE_DIR/PLANNING.md. Follow project conventions in $REPO_ROOT/docs. Write clean, tested code matching existing patterns. Create or update unit tests. $PATH_NOTE" \
      "$(feature_context)" \
      "" \
      "$BASE" "$PLANNING"
    ;;

  refactor)
    require_files "$BASE" "$REVIEW"
    run "Apply the refactoring described in $AI_PRIVATE_DIR/REVIEW.md. Preserve existing behavior while improving code quality. Follow project conventions in $REPO_ROOT/docs. Ensure all tests pass. $PATH_NOTE. Create a refactoring summary inside $AI_PRIVATE_DIR/REFACTOR.md (if exists, overwrite)." \
      "$(refactor_context)" \
      "" \
      "$BASE" "$REVIEW"
    ;;

  review)
    require_files "$BASE" "$REVIEW"
    run "Review changed files against master. Check for: bugs, style violations (per docs/), missing tests, performance issues, security concerns. Write findings to $AI_PRIVATE_DIR/REVIEW.md (if exists, overwrite) with actionable suggestions grouped by severity. $(html_task_instruction) $PATH_NOTE" \
      "$(review_context)" \
      "" \
      "git status; git log master..HEAD --oneline; git diff --name-only master...HEAD" \
      "$BASE" "$REVIEW"
    ;;

  planning)
    require_files "$BASE" "$PLANNING" "$FEATURE"
    run "Create an implementation plan for the feature in $AI_PRIVATE_DIR/FEATURE.md (if exists, overwrite). Do NOT modify source files. Output: 1) Architecture overview, 2) Files to create/modify, 3) Risks and mitigations, 4) Implementation order, 5) Test strategy. Write the plan to $AI_PRIVATE_DIR/PLANNING.md. $(html_task_instruction) $PATH_NOTE" \
      "$(planning_context)" \
      "opus" \
      "git status; git log master..HEAD --oneline; git log master --oneline -5; find . -maxdepth 3 -type f \\( -name '*.ts' -o -name '*.tsx' -o -name '*.js' \\) | head -100" \
      "$BASE" "$PLANNING" "$FEATURE"
    ;;

  *)
    usage
    exit 1
    ;;
esac